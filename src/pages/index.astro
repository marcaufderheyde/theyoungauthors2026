---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allContent = await getCollection('blog');
// Filter only posts for the feed, sort by date descending
const posts = allContent
  .filter(entry => entry.data.type === 'post')
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
---

<Layout title="Home">
  <div class="px-6 py-12 max-w-5xl mx-auto">
    <!-- Welcome Section -->
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-800 mb-6 font-serif">Welcome to the Young Authors!</h1>
      <p class="text-lg text-slate-600">
        Check out our Roadmap for 2026-2027: <a href="/news" class="text-primary hover:text-primary/80 underline decoration-2 underline-offset-4 transition-colors font-medium">Click Here</a>
      </p>
    </div>

    <!-- Feed Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.map(post => (
        <PostCard 
          title={post.data.title}
          url={`/${post.id}`}
          date={post.data.date}
          author={post.data.author}
          coverImage={post.data.cover_image}
        />
      ))}
    </div>
  </div>
</Layout>
