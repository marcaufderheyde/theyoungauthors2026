---
interface Props {
  title: string;
  url: string;
  date: string | Date;
  author?: string;
  coverImage?: string;
}

const { title, url, date, author, coverImage } = Astro.props;

// Format date nicely
const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<article class="group relative bg-white border border-slate-100 rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col h-full">
  {coverImage ? (
    <div class="h-48 overflow-hidden bg-slate-100">
      <img 
        src={coverImage} 
        alt={title} 
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
        loading="lazy"
      />
    </div>
  ) : (
    <div class="h-48 bg-gradient-to-br from-slate-50 to-slate-100 flex items-center justify-center border-b border-slate-50">
      <svg class="w-12 h-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
      </svg>
    </div>
  )}
  
  <div class="p-6 flex flex-col flex-grow">
    <div class="text-xs font-semibold text-primary/70 uppercase tracking-wider mb-2 flex items-center gap-2">
      <time datetime={new Date(date).toISOString()}>{formattedDate}</time>
      {author && author !== 'Unknown' && (
        <>
          <span class="w-1 h-1 rounded-full bg-slate-300"></span>
          <span>By {author}</span>
        </>
      )}
    </div>
    
    <h3 class="text-xl font-bold text-slate-800 leading-tight mb-4 group-hover:text-primary transition-colors line-clamp-2">
      <a href={url} class="after:absolute after:inset-0">
        {title}
      </a>
    </h3>
    
    <div class="mt-auto flex items-center text-sm font-medium text-primary">
      Read article 
      <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
      </svg>
    </div>
  </div>
</article>
