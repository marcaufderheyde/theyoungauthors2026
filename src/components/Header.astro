---
import { getCollection } from 'astro:content';

const allContent = await getCollection('blog');
const posts = allContent.filter(entry => entry.data.type === 'post');
const postUrls = posts.map(p => `/${p.id}`);
---
<header class="w-full flex flex-col">
  <!-- Top Bar -->
  <div class="bg-primary text-white/90 text-sm py-1.5 px-6 flex justify-between items-center shadow-inner">
    <button id="random-btn" class="hover:text-white transition-colors cursor-pointer bg-transparent border-none p-0">Random Submission</button>
  </div>

  <!-- Navigation -->
  <nav class="bg-white py-4 px-6 sticky top-0 z-50 shadow-sm border-b border-slate-100 flex flex-wrap justify-between items-center relative">
    <div class="md:hidden w-full flex justify-end">
      <button id="mobile-menu-btn" class="text-slate-800 p-2 focus:outline-none">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
    <ul id="nav-menu" class="hidden md:flex w-full md:w-auto flex-col md:flex-row flex-wrap justify-end md:ml-auto gap-x-8 gap-y-4 text-base font-medium text-slate-800 mt-4 md:mt-0 transition-all">
      <li><a href="/" class="block hover:text-primary transition-colors relative after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-full after:bg-primary after:origin-center after:scale-x-0 hover:after:scale-x-100 after:transition-transform">Home</a></li>
      <li><a href="/about-us" class="block hover:text-primary transition-colors relative after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-full after:bg-primary after:origin-center after:scale-x-0 hover:after:scale-x-100 after:transition-transform">About Us</a></li>
      <li><a href="/submissions" class="block hover:text-primary transition-colors relative after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-full after:bg-primary after:origin-center after:scale-x-0 hover:after:scale-x-100 after:transition-transform">Submissions</a></li>
      <li><a href="/news" class="block hover:text-primary transition-colors relative after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-full after:bg-primary after:origin-center after:scale-x-0 hover:after:scale-x-100 after:transition-transform">News</a></li>
      <li><a href="/sponsors" class="block hover:text-primary transition-colors relative after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-full after:bg-primary after:origin-center after:scale-x-0 hover:after:scale-x-100 after:transition-transform">Sponsors</a></li>
    </ul>
  </nav>

  <!-- Hero Banner -->
  <div class="relative w-full h-[280px] bg-slate-800 overflow-hidden group">
    <!-- Abstract Book Spine Background. In a real app this would be an image, but we'll use a CSS gradient pattern to simulate the colorful books, or we can use a placeholder image from Unsplash. -->
    <img src="https://images.unsplash.com/photo-1507842217343-583bb7270b66?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80" alt="Books on a shelf" class="w-full h-full object-cover opacity-90 group-hover:scale-105 transition-transform duration-700 ease-out" />
    
    <div class="absolute inset-0 flex items-center justify-center">
      <!-- Glassmorphism Logo Box -->
      <div class="bg-white/70 backdrop-blur-md border-4 border-primary/80 px-8 py-6 shadow-2xl transform transition-all hover:scale-105 duration-300 flex items-center gap-4 group-hover:bg-white/80">
        <div class="text-primary text-5xl font-light tracking-widest leading-none flex flex-col">
          <span>THE</span>
          <span class="font-medium">YOUNG</span>
          <span class="font-bold tracking-widest">AUTHORS</span>
        </div>
        <!-- Abstract Logo Shape -->
        <div class="w-12 h-20 border-4 border-primary/80 rounded-t-lg rounded-br-3xl flex flex-col items-center pt-2 relative">
           <div class="w-4 h-1 bg-primary/80 absolute top-3 -left-1"></div>
           <div class="w-3 h-3 border-2 border-primary/80 rounded-full mt-1"></div>
        </div>
      </div>
    </div>
  </div>
</header>

<script is:inline define:vars={{ postUrls }}>
  // Random button logic
  const randomBtn = document.getElementById('random-btn');
  if (randomBtn && postUrls.length > 0) {
    randomBtn.addEventListener('click', (e) => {
      e.preventDefault();
      const randomIndex = Math.floor(Math.random() * postUrls.length);
      window.location.href = postUrls[randomIndex];
    });
  }

  // Mobile menu logic
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const navMenu = document.getElementById('nav-menu');
  if (mobileBtn && navMenu) {
    mobileBtn.addEventListener('click', () => {
      navMenu.classList.toggle('hidden');
      navMenu.classList.toggle('flex');
    });
  }
</script>
