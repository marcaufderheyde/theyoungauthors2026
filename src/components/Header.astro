---
---
<header class="w-full flex flex-col">
  <!-- Top Bar -->
  <div class="bg-primary text-white/90 text-sm py-1.5 px-6 flex justify-between items-center shadow-inner">
    <a href="#" class="hover:text-white transition-colors">Random Submission</a>
    
    <div class="relative">
      <input 
        type="search" 
        placeholder="Search" 
        class="bg-white/20 border border-white/30 text-white placeholder-white/70 rounded-sm px-3 py-0.5 pl-8 text-sm focus:outline-none focus:ring-2 focus:ring-white/50 focus:bg-white/30 transition-all w-48"
      />
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 absolute left-2.5 top-1 text-white/70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
    </div>
  </div>

  <!-- Navigation -->
  <nav class="bg-white py-5 px-6 sticky top-0 z-50 shadow-sm border-b border-slate-100">
    <ul class="flex flex-wrap justify-center gap-x-8 gap-y-4 text-base font-medium text-slate-800">
      <li><a href="/" class="hover:text-primary transition-colors relative after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-full after:bg-primary after:origin-center after:scale-x-0 hover:after:scale-x-100 after:transition-transform">Home</a></li>
      <li><a href="/about-us" class="hover:text-primary transition-colors relative after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-full after:bg-primary after:origin-center after:scale-x-0 hover:after:scale-x-100 after:transition-transform">About Us</a></li>
      <li><a href="/submissions" class="hover:text-primary transition-colors relative after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-full after:bg-primary after:origin-center after:scale-x-0 hover:after:scale-x-100 after:transition-transform">Submissions</a></li>
      <li><a href="/news" class="hover:text-primary transition-colors relative after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-full after:bg-primary after:origin-center after:scale-x-0 hover:after:scale-x-100 after:transition-transform">News</a></li>
      <li><a href="/sponsors" class="hover:text-primary transition-colors relative after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-full after:bg-primary after:origin-center after:scale-x-0 hover:after:scale-x-100 after:transition-transform">Sponsors</a></li>
      <li><a href="/contact" class="hover:text-primary transition-colors relative after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-full after:bg-primary after:origin-center after:scale-x-0 hover:after:scale-x-100 after:transition-transform">Contact</a></li>
      <li><a href="#" class="hover:text-primary transition-colors relative after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-full after:bg-primary after:origin-center after:scale-x-0 hover:after:scale-x-100 after:transition-transform">Log In</a></li>
    </ul>
  </nav>

  <!-- Hero Banner -->
  <div class="relative w-full h-[280px] bg-slate-800 overflow-hidden group">
    <!-- Abstract Book Spine Background. In a real app this would be an image, but we'll use a CSS gradient pattern to simulate the colorful books, or we can use a placeholder image from Unsplash. -->
    <img src="https://images.unsplash.com/photo-1507842217343-583bb7270b66?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80" alt="Books on a shelf" class="w-full h-full object-cover opacity-90 group-hover:scale-105 transition-transform duration-700 ease-out" />
    
    <div class="absolute inset-0 flex items-center justify-center">
      <!-- Glassmorphism Logo Box -->
      <div class="bg-white/70 backdrop-blur-md border-4 border-primary/80 px-8 py-6 shadow-2xl transform transition-all hover:scale-105 duration-300 flex items-center gap-4 group-hover:bg-white/80">
        <div class="text-primary text-5xl font-light tracking-widest leading-none flex flex-col">
          <span>THE</span>
          <span class="font-medium">YOUNG</span>
          <span class="font-bold tracking-widest">AUTHORS</span>
        </div>
        <!-- Abstract Logo Shape -->
        <div class="w-12 h-20 border-4 border-primary/80 rounded-t-lg rounded-br-3xl flex flex-col items-center pt-2 relative">
           <div class="w-4 h-1 bg-primary/80 absolute top-3 -left-1"></div>
           <div class="w-3 h-3 border-2 border-primary/80 rounded-full mt-1"></div>
        </div>
      </div>
    </div>
  </div>
</header>
