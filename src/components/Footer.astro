---
---
<div class="bg-white py-12 px-6 flex justify-center border-t border-slate-100">
  <blockquote class="text-center max-w-2xl">
    <p class="font-serif text-slate-600 italic text-sm mb-2">"There is no surer foundation for a beautiful friendship than a mutual taste in literature."</p>
    <footer class="text-xs text-slate-500 font-sans tracking-wide uppercase">— P.G. Wodehouse</footer>
  </blockquote>
</div>

<footer class="bg-footer text-primary text-xs py-8 px-6 relative border-t border-slate-200">
  <div class="max-w-4xl mx-auto">
    <nav class="mb-8">
      <ul class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-slate-500">
        <li><a href="/terms-of-use" class="hover:text-primary transition-colors">Terms of Use</a></li>
        <li><a href="/imprint" class="hover:text-primary transition-colors">Imprint</a></li>
      </ul>
    </nav>
    
    <div class="text-center text-slate-500 font-sans">
      &copy; The Young Authors {new Date().getFullYear()}
    </div>
  </div>

  <!-- Scroll to top button -->
  <button 
    onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
    class="absolute right-6 bottom-6 bg-slate-300 hover:bg-slate-400 text-white p-1.5 shadow-sm transition-colors"
    aria-label="Scroll to top"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
    </svg>
  </button>
</footer>
