---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="The Young Authors - A platform for young writers" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Merriweather:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
		<title>{title} | The Young Authors</title>
	</head>
	<body class="min-h-screen flex flex-col font-sans text-slate-800 selection:bg-primary/20 selection:text-primary">
		<div class="flex-grow max-w-[1200px] w-full mx-auto my-0 bg-white/98 backdrop-blur-md shadow-2xl shadow-primary/10 flex flex-col relative z-10 border-x border-slate-100">
			<Header />
			
			<main class="flex-grow">
				<slot />
			</main>
			
			<Footer />
		</div>
	</body>
</html>
